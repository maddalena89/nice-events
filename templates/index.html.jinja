// ---- snap-a-flyer: in-browser OCR, nothing leaves the device ----
// The heavy Tesseract library is loaded only when someone actually picks a
// photo — it must never slow the normal page load for the 99% who don't.
const FLYER = (() => {
  const MONTHS = {jan:1,janv:1,janvier:1,fev:2,fevr:2,fevrier:2,"février":2,mar:3,mars:3,
    avr:4,avril:4,mai:5,jui:6,juin:6,juil:7,juillet:7,aou:8,aout:8,"août":8,
    sep:9,sept:9,septembre:9,oct:10,octobre:10,nov:11,novembre:12,dec:12,"déc":12,decembre:12,"décembre":12};
  const fold=s=>s.normalize("NFD").replace(/[\u0300-\u036f]/g,"").toLowerCase();

  const pad=n=>String(n).padStart(2,"0");
  const ymd=(y,mon,day)=>`${y}-${pad(mon)}-${pad(day)}`;
  // Roll a bare day+month to the next occurrence, so "18 juillet" on a poster
  // seen in December means next July, not one already gone. Built from calendar
  // components — NEVER via Date()+toISOString(), whose UTC round-trip shifts the
  // day (and sometimes the year) for anyone not exactly on UTC.
  function rollDate(day,mon){
    const t=new Date(), tm=t.getMonth()+1, td=t.getDate();
    let y=t.getFullYear();
    if(mon<tm || (mon===tm && day<td)) y+=1;
    return ymd(y,mon,day);
  }
  function parseDate(text){
    const f=fold(text);
    // "18 juillet 2026" | "18 juil" | "sam 18 juillet"
    let m=f.match(/\b(\d{1,2})\s+([a-z]{3,9})\.?(?:\s+(\d{4}))?/);
    if(m && MONTHS[m[2]]){
      const day=+m[1], mon=MONTHS[m[2]];
      return m[3] ? ymd(+m[3],mon,day) : rollDate(day,mon);
    }
    // "18/07/2026" | "18/07"
    m=f.match(/\b(\d{1,2})\/(\d{1,2})(?:\/(\d{2,4}))?/);
    if(m){
      const day=+m[1], mon=+m[2];
      if(mon>=1&&mon<=12&&day>=1&&day<=31){
        const yr=m[3]?(m[3].length===2?2000+ +m[3]:+m[3]):null;
        return yr ? ymd(yr,mon,day) : rollDate(day,mon);
      }
    }
    return "";
  }
  function parseTime(text){
    const m=fold(text).match(/\b(\d{1,2})\s*[h:]\s*(\d{2})?\b/);
    if(m){const hh=+m[1]; if(hh<=23) return `${hh}h${m[2]||""}`;}
    return "";
  }
  const CAT_HINTS=[
    [/concert|dj\b|jazz|live|techno|house|electro|rock|rap|hip.?hop|club\b|soiree|apero.?club/,"concert"],
    [/expo|exposition|vernissage|galerie/,"expo"],
    [/theatre|spectacle|opera|ballet|humour|one.?man|cirque|impro/,"scene"],
    [/tango|milonga|salsa|bachata|kizomba|danse|dance|\bbal\b|swing|lindy/,"danse"],
    [/brocante|vide.?grenier|braderie|bourse/,"brocante"],
    [/atelier|workshop|\bstage\b|masterclass|initiation/,"atelier"],
    [/conference|meetup|networking|startup|business|pitch|forum/,"business"],
    [/marche\b|\bfete\b|foire|festin|carnaval|kermesse/,"marche"],
    [/visite|balade|parcours|patrimoine/,"visite"],
    [/yoga|course|trail|rando|match|tournoi|petanque|marathon/,"sport"],
    [/apero|rencontre|expat|quiz|jeux|blind.?test/,"social"],
  ];
  function guessCategory(text){
    const f=fold(text);
    for(const [re,cat] of CAT_HINTS) if(re.test(f)) return cat;
    return "";
  }
  function guessTown(text){
    const f=fold(text);
    for(const t of TOWNS) if(f.includes(fold(t))) return t;   // TOWNS defined above
    return "";
  }
  function guessTitle(text){
    // First substantial line that isn't a date, time, price or URL.
    const bad=/^\s*$|^\d|https?:|www\.|\d\s*€|gratuit|entree|\bh\d|^\W+$/i;
    const lines=text.split("\n").map(s=>s.trim()).filter(s=>s.length>=4 && !bad.test(s));
    // Prefer an ALL-CAPS / long line near the top (posters shout their title).
    lines.sort((a,b)=> (b===b.toUpperCase()?1:0)-(a===a.toUpperCase()?1:0));
    return (lines[0]||"").slice(0,120);
  }

  // Pure text -> fields. Exposed for testing; the OCR engine feeds it.
  function parse(text){
    return {
      title: guessTitle(text),
      date: parseDate(text),
      time: parseTime(text),
      town: guessTown(text),
      category: guessCategory(text),
      note: text.replace(/\s+/g," ").trim().slice(0,300),
    };
  }
  return {parse, parseDate, parseTime, guessCategory, guessTown, guessTitle};
})();

(() => {
  const inp=$("s-photo"), msg=$("snap-msg");
  if(!inp) return;
  // When set (an AI vision endpoint is configured), the poster is read by the
  // model; empty string keeps the original on-device OCR. Either way the OCR is
  // the fallback if the endpoint is slow or down, so this never fully breaks.
  const POSTER_AI = {{ poster_ai_url|tojson }};
  const POSTER_AI_KEY = {{ poster_ai_key|tojson }};
  let loading=null;
  const setMsg=(t,cls="")=>{msg.textContent=t; msg.className="snap-msg"+(cls?" "+cls:"");};

  function loadTesseract(){
    if(window.Tesseract) return Promise.resolve();
    if(loading) return loading;
    loading=new Promise((res,rej)=>{
      const s=document.createElement("script");
      s.src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js";
      s.onload=res; s.onerror=()=>rej(new Error("load failed"));
      document.head.appendChild(s);
    });
    return loading;
  }

  // Shrink a phone photo before upload: big enough to read, small enough to be
  // fast and stay under the endpoint's size cap. Falls back to the original file.
  async function downscale(file, max=1600, q=0.85){
    let bmp=null;
    try{ bmp=await createImageBitmap(file); }catch(_){ return file; }
    const s=Math.min(1, max/Math.max(bmp.width,bmp.height));
    if(s>=1 && file.size<1200000) return file;
    const w=Math.round(bmp.width*s), h=Math.round(bmp.height*s);
    const cv=document.createElement("canvas"); cv.width=w; cv.height=h;
    cv.getContext("2d").drawImage(bmp,0,0,w,h);
    return await new Promise(res=>cv.toBlob(b=>res(b||file),"image/jpeg",q));
  }

  // Ask the vision endpoint to read the poster. Throws on any failure so the
  // caller can fall back to on-device OCR.
  async function readPosterAI(file){
    const img=await downscale(file);
    const fd=new FormData(); fd.append("photo", img, "poster.jpg");
    const headers={};
    if(POSTER_AI_KEY){ headers.apikey=POSTER_AI_KEY; headers.Authorization="Bearer "+POSTER_AI_KEY; }
    const r=await fetch(POSTER_AI, {method:"POST", headers, body:fd});
    if(!r.ok) throw new Error("ai "+r.status);
    const j=await r.json();
    if(!j || !j.ok || !j.fields) throw new Error("ai empty");
    return j.fields;
  }

  const setV=(id,v)=>{ if(v && $(id) && !$(id).value) $(id).value=v; };

  // On-device OCR result -> form.
  function fill(f){
    setV("s-title",f.title); setV("s-date",f.date); setV("s-town",f.town);
    if(f.category && $("s-cat")) $("s-cat").value=f.category;
    const note=[f.time?("Heure : "+f.time):"", f.note].filter(Boolean).join(" · ");
    setV("s-note",note.slice(0,300));
  }
  // AI result (richer shape: start_date / end_date / venue) -> form.
  function fillAI(f){
    setV("s-title",f.title); setV("s-date",f.start_date); setV("s-end",f.end_date);
    setV("s-time",f.time);   // the model returns HH:MM, which the time input wants
    setV("s-town",f.town); setV("s-venue",f.venue);
    if(f.category && $("s-cat") && [...$("s-cat").options].some(o=>o.value===f.category)) $("s-cat").value=f.category;
    if(f.note) setV("s-note",String(f.note).slice(0,300));
  }

  async function ocrFallback(file){
    setMsg("Reading the poster…","busy");
    await loadTesseract();
    const {data}=await window.Tesseract.recognize(file,"fra");
    const text=(data && data.text)||"";
    if(!text.trim()){ setMsg("Couldn't read that one. Try filling it in by hand?"); return; }
    fill(FLYER.parse(text));
    setMsg("Filled in what we could. Please check every field.","done");
  }

  inp.addEventListener("change", async () => {
    const file=inp.files && inp.files[0];
    if(!file) return;
    try{
      if(POSTER_AI){
        setMsg("Reading the poster…","busy");
        try{
          fillAI(await readPosterAI(file));
          setMsg("Filled it in. Please check every field before sending.","done");
          return;
        }catch(_){ /* endpoint slow or down: quietly fall back to on-device OCR */ }
      }
      await ocrFallback(file);
    }catch(e){
      setMsg("Couldn't read that one. Try filling it in by hand?");
    }finally{
      inp.value="";  // let the same photo be re-picked
    }
  });
})();

{% if submit_mode == 'supabase' %}
// Posts straight to Supabase from the browser. No server of our own.
//
// These two values are public and that is by design — anyone can read them out
// of this page. They identify the project; they authorise nothing. What stops a
// stranger writing rubbish into the table is Row Level Security (insert-only,
// plus CHECK constraints), not the secrecy of this key. tojson, not bare
// interpolation, so the values can't break out of the string literal.
const SB_URL = {{ supabase_url|tojson }};
const SB_KEY = {{ supabase_anon_key|tojson }};
// Belt-and-suspenders: if the project URL was set with a trailing /rest/v1 (a
// common mistake that yields PGRST125 "Invalid path"), strip it so the endpoint
// below is always exactly one /rest/v1/… deep.
const SB_REST = SB_URL.replace(/\/+$/,"").replace(/\/rest(\/v1)?$/,"") + "/rest/v1/submissions";

// Turn a raw PostgREST/Postgres error into something a human can act on. The DB
// speaks in constraint names; people don't. Never show the raw JSON.
function friendlySubmitError(text, status){
  const t = (text || "").toLowerCase();
  if (t.includes("start_sane"))       return "Please pick an upcoming date (2024 or later).";
  if (t.includes("end_after_start"))  return "The end date can't be before the start date.";
  if (t.includes("title_len"))        return "The event name needs to be 3 to 200 characters.";
  if (t.includes("town_len"))         return "That town name doesn't look right.";
  if (t.includes("url_is_http") || t.includes("regular expression") || t.includes("repetition count"))
                                      return "That link doesn't look right. Paste a full web address starting with https://.";
  if (t.includes("category"))         return "Please choose a category from the list.";
  if (t.includes("email"))            return "That email address doesn't look right.";
  if (status === 409 || t.includes("duplicate")) return "That event looks like it's already listed.";
  return "Sorry, that didn't go through. Please double-check the fields and try again.";
}

$("sform").addEventListener("submit", async ev => {
  ev.preventDefault();
  const g = id => $(id).value.trim();
  const msg = $("smsg");
  const btn = $("sform").querySelector("button[type=submit]");

  const bad = m => { msg.innerHTML = '<span class="err">' + m + '</span>'; };

  // Required: everything except Ends, Note and Link.
  if (!g("s-title")) { bad("Please add an event name."); return; }

  // Town must be one already on the site — the datalist suggests them, this
  // enforces it. We store the canonical spelling, so "nice"/"NICE" -> "Nice".
  const townCanon = TOWN_CANON.get(g("s-town").toLowerCase());
  if (!townCanon) { bad("Pick a town from the list as you type."); return; }
  if (!g("s-venue")) { bad("Please add a venue."); return; }

  const email = g("s-email");
  if (!email) { bad("Please add your email."); return; }
  if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) { bad("That email address doesn't look right."); return; }

  // Date + time. An events site is about what's coming up, so a past date is
  // almost always a typo — catch it kindly rather than via a DB constraint.
  const startD = g("s-date");
  if (!startD) { bad("Please add a date."); return; }
  if (startD < TODAY) { bad("That date is in the past. Pick an upcoming date."); return; }
  const endD = g("s-end");
  if (endD && endD < startD) { bad("The end date can't be before the start date."); return; }
  if (!g("s-time")) { bad("Please add a start time."); return; }

  // Link is OPTIONAL now (the email identifies the submitter). Validate if given.
  const raw = g("s-url");
  if (raw) {
    let u;
    try { u = new URL(raw); } catch { bad("That link isn't a valid URL."); return; }
    if (u.protocol !== "https:" && u.protocol !== "http:") { bad("The link must start with http:// or https://."); return; }
  }

  btn.disabled = true;
  msg.innerHTML = "Sending…";
  try {
    const r = await fetch(SB_REST, {
      method: "POST",
      headers: {
        "apikey": SB_KEY,
        "Authorization": "Bearer " + SB_KEY,
        "Content-Type": "application/json",
        "Prefer": "return=minimal",
      },
      // approved/published are deliberately not sent. The RLS policy requires
      // them to be false, and the column defaults already are.
      body: JSON.stringify({
        title: g("s-title"),
        start_date: g("s-date"),
        end_date: g("s-end") || null,
        time: g("s-time") || null,
        town: townCanon,
        venue: g("s-venue"),
        category: $("s-cat").value,
        url: raw || null,
        note: g("s-note") || null,
        email: email,
      }),
    });
    if (r.ok) {
      // Snapshot what they typed BEFORE reset, so they can grab a shareable card
      // for the event they just added — the little reward for contributing.
      const card = { title:g("s-title"), start:g("s-date"), end:g("s-end")||null,
                     time:g("s-time")||null, town:townCanon, venue:g("s-venue")||null,
                     category:$("s-cat").value };
      $("sform").reset();
      msg.innerHTML = '<span class="ok">Thank you! It\'s queued for review.</span> ';
      if (card.title && card.start) {
        const cb=document.createElement("button");
        cb.type="button"; cb.textContent="📇 Get a shareable card";
        cb.style.cssText="margin-left:8px;min-height:0;padding:6px 10px";
        cb.onclick=()=>shareEventCard(card,null);
        msg.appendChild(cb);
      }
    } else {
      // Translate the real reason into plain language — never dump raw JSON at
      // someone who just typed out their event.
      const t = await r.text();
      msg.innerHTML = '<span class="err">' + esc(friendlySubmitError(t, r.status)) + '</span>';
    }
  } catch (err) {
    msg.innerHTML = '<span class="err">Couldn\'t reach the server. Please try again in a moment.</span>';
  } finally {
    btn.disabled = false;
  }
});
{% endif %}

