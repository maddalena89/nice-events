</div>

</div>

<script id="data" type="application/json">{{ events_json }}</script>
<script>
const EVENTS = JSON.parse(document.getElementById("data").textContent);
const CATNAME = {{ cat_json }};
const $ = id => document.getElementById(id);
const iso = d => d.toISOString().slice(0,10);
const TODAY = iso(new Date());
let active = new Set();

// Share: a link back to this site with one event flagged (?e=<id>), which the
// page highlights in blue and scrolls to. SITE is the clean base with no query.
const SITE = location.origin + location.pathname;
// Directory the page is served from (so links work at the domain root or under a
// project path), and the canonical production host from the CNAME — used so the
// printed short link and QR read "whatsonnice.com/jasmine" even in local preview.
const BASE = location.origin + location.pathname.replace(/[^/]*$/, "");
const CANON_HOST = {{ canonical_host|tojson }};
const LINKBASE = CANON_HOST ? ("https://" + CANON_HOST + "/") : BASE;
const HOSTDISP = CANON_HOST || BASE.replace(/^https?:\/\//, "").replace(/\/$/, "");
// The ?e= value can be a fingerprint (old share links) OR a slug (new short links,
// and what 404.html rewrites /jasmine into). Resolved to a fingerprint below.
const HL_PARAM = new URLSearchParams(location.search).get("e");
const SHARE_SVG = '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"/><path d="M12 15V3"/><path d="M8 7l4-4 4 4"/></svg>';
const CAL_SVG = '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4M12 13v4M10 15h4"/></svg>';
// Shareable image card — a little "download picture" glyph.
const CARD_SVG = '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="3"/><path d="M3 15l4-4 3 3 4-4 7 6"/><circle cx="9" cy="10" r="1.4"/></svg>';
// Look up the full event by fingerprint (rows only carry the id, and a
// multi-day show appears on several rows but is one event here).
const FP_MAP = new Map(EVENTS.map(e => [e.fingerprint, e]));
const SLUG_MAP = new Map(EVENTS.filter(e => e.slug).map(e => [e.slug, e]));
// Resolve the shared identifier (slug or fingerprint) to a fingerprint we can
// highlight. Unknown value -> keep it as-is (nothing matches, page loads clean).
const HL_HIT = FP_MAP.get(HL_PARAM) || SLUG_MAP.get(HL_PARAM);
const HL_FP = HL_HIT ? HL_HIT.fingerprint : HL_PARAM;

$("mq").innerHTML = (() => {
  const b = ["Vide-greniers","Milongas","Jazz","Brocantes","Exhibitions","Club nights",
             "Design meetups","AI & tech","Village fêtes","Pop-ups","Vernissages","Expat socials",
             "Beaulieu-sur-Mer","Villefranche","Èze","Cagnes","Antibes","Cours Saleya"];
  const r = b.map(x=>`<span>${x}</span>`).join(""); return r+r;
})();

const cats = [...new Set(EVENTS.map(e=>e.category))]
  .sort((a,b)=>Object.keys(CATNAME).indexOf(a)-Object.keys(CATNAME).indexOf(b));
cats.forEach(k=>{
  const el=document.createElement("div");
  el.className="cat"; el.dataset.k=k;
  el.innerHTML=`${CATNAME[k]||k}<i>0</i>`;
  el.onclick=()=>{active.has(k)?active.delete(k):active.add(k);el.classList.toggle("on");render();};
  $("cats").appendChild(el);
});

// Towns you can physically go to. "Online" is a format, not a place — it must
// not appear in a list headed "All towns", nor in the submission datalist.
// One source of truth, used three ways: the filter dropdown, the submission
// datalist, and the submit-time validation set.
const TOWNS = [...new Set(EVENTS.filter(e=>!e.online).map(e=>e.town))]
  .sort((a,b)=>a.localeCompare(b,"fr"));
const TOWN_CANON = new Map(TOWNS.map(t=>[t.toLowerCase(), t]));  // typed -> canonical

TOWNS.forEach(t=>{
  const o=document.createElement("option"); o.value=o.textContent=t;
  $("town").appendChild(o);
});
{
  const dl=$("townlist");
  if(dl) TOWNS.forEach(t=>{const o=document.createElement("option");o.value=t;dl.appendChild(o);});
}

function weekendRange(){
  const n=new Date(),d=n.getDay();
  const sat=new Date(n); sat.setDate(n.getDate()+((6-d+7)%7));
  const sun=new Date(sat); sun.setDate(sat.getDate()+1);
  return [iso(sat),iso(sun)];
}
const overlaps=(e,f,t)=>e.start<=t&&(e.end||e.start)>=f;
const esc=s=>String(s).replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[m]));
const fmtDay=d=>new Date(d+"T12:00:00").toLocaleDateString("en-GB",{weekday:"long",day:"numeric",month:"long"});
const fmtYr=d=>new Date(d+"T12:00:00").toLocaleDateString("en-GB",{year:"numeric"});
const fmtShort=d=>new Date(d+"T12:00:00").toLocaleDateString("en-GB",{day:"numeric",month:"short"});
const addDays=(d,n)=>{const x=new Date(d+"T12:00:00");x.setDate(x.getDate()+n);return iso(x);};
const isMultiDay=e=>e.end&&e.end!==e.start;

// A month-long exhibition should read as one thing that runs for a while — this
// is the "from here to here" sticker. Ongoing -> "until 31 Aug"; upcoming ->
// "5 Aug – 31 Aug".
function runBadge(e){
  if(!isMultiDay(e)) return "";
  const txt = e.start<TODAY ? `until ${fmtShort(e.end)}`
                            : `${fmtShort(e.start)} – ${fmtShort(e.end)}`;
  return `<span class="pill run">${txt}</span>`;
}

// When a category is being browsed, a running exhibition should appear on every
// day it's open — so "what's on this Saturday" actually shows it. In the full
// list (no category picked) it appears once, carrying the range badge instead,
// or the page would drown in identical repeated rows.
// Capped so "Any date" + a year-long show can't emit hundreds of rows.
const EXPAND_CAP_DAYS = 31;
function occurrences(e, from, to, expand){
  const first = e.start < from ? from : e.start;
  if(!expand || !isMultiDay(e)) return [first];
  const horizon = [to, addDays(TODAY, EXPAND_CAP_DAYS), e.end]
    .reduce((a,b)=> a<b ? a : b);
  const out=[]; let d=first;
  while(d <= horizon){ out.push(d); d=addDays(d,1); }
  return out.length ? out : [first];
}

function render(){
  const q=$("q").value.trim().toLowerCase(), town=$("town").value, when=$("when").value;
  // Online events are off unless asked for. This site is about being somewhere;
  // a Zoom call that surfaced under "near Nice" is noise until someone opts in.
  const showOnline=$("online").checked;
  const freeOnly=$("freeonly").checked;
  let from=TODAY,to="2099-12-31";
  if(when==="weekend") [from,to]=weekendRange();
  else if(when){const e=new Date();e.setDate(e.getDate()+ +when);to=iso(e);}

  const base=EVENTS.filter(e=>(!town||e.town===town)&&overlaps(e,from,to)&&
    (showOnline||!e.online)&&
    (!freeOnly||e.free)&&
    (!q||`${e.title} ${e.town} ${e.venue||""} ${e.note||""}`.toLowerCase().includes(q)));
  [...$("cats").children].forEach(el=>{
    el.querySelector("i").textContent=base.filter(e=>e.category===el.dataset.k).length;});

  // Unique events that pass the category filter — this is what the tally counts,
  // so "42 listings" means 42 events, never 42 × the days they run.
  const matched=base.filter(e=>!active.size||active.has(e.category));

  // Expand to (day, event) pairs. Only when a category is being browsed does a
  // multi-day show repeat per day; in the full list each appears once.
  const expand=active.size>0;
  const pairs=[];
  matched.forEach(e=>occurrences(e,from,to,expand).forEach(day=>pairs.push([day,e])));
  pairs.sort((a,b)=>a[0].localeCompare(b[0])||
    a[1].town.localeCompare(b[1].town,"fr")||a[1].title.localeCompare(b[1].title));

  const w=new Date(); w.setDate(w.getDate()+7);
  // Must honour the same online rule as the list, or the headline number
  // promises events the page then refuses to show.
  $("s-week").textContent=EVENTS.filter(e=>(showOnline||!e.online)&&
    (!freeOnly||e.free)&&overlaps(e,TODAY,iso(w))).length;
  $("tally").textContent=`${matched.length} listing${matched.length===1?"":"s"}`+
    (when?" in range":"")+(town?` · ${town}`:"")+(active.size?" · filtered":"");

  const list=$("list"); list.innerHTML="";
  if(!pairs.length){list.innerHTML='<div class="empty">Nothing matches those filters.</div>';return;}

  let last=null,i=0;
  pairs.forEach(([slot,e])=>{
    const ongoing=e.start<slot;
    if(slot!==last){
      const h=document.createElement("div"); h.className="daymark";
      h.innerHTML=`<b>${fmtDay(slot)}</b><span>${fmtYr(slot)}</span>`;
      list.appendChild(h); last=slot;
    }
    i++;
    const r=document.createElement("div"); r.className="row"; r.dataset.fp=e.fingerprint;
    if(e.fingerprint===HL_FP) r.classList.add("hl");
    r.innerHTML=`
      <div class="idx">${String(i).padStart(2,"0")}</div>
      <div>
        <div class="ttl">
          ${e.free?'<span class="pill free">Free</span>':""}
          ${e.outdoor?'<span class="pill out">Outdoor</span>':""}
          ${e.online?'<span class="pill out">Online</span>':""}
          ${runBadge(e)}
          ${e.url?`<a href="${esc(e.url)}" target="_blank" rel="noopener nofollow">${esc(e.title)}</a>`:esc(e.title)}
          <button class="calbtn" data-fp="${esc(e.fingerprint)}" aria-label="Add to calendar" title="Add to calendar">${CAL_SVG}</button>
          <button class="sharebtn" data-fp="${esc(e.fingerprint)}" data-title="${esc(e.title)}" aria-label="Share this event" title="Share">${SHARE_SVG}</button>
          <button class="cardbtn" data-fp="${esc(e.fingerprint)}" aria-label="Get a shareable card" title="Shareable card">${CARD_SVG}</button>
        </div>
        ${e.note?`<div class="sub">${esc(e.note)}</div>`:""}
      </div>
      <div class="where"><b>${esc(e.town)}</b>
        <span>${e.venue?esc(e.venue):""}</span></div>
      <div class="kind">${esc(CATNAME[e.category]||e.category)}</div>`;
    list.appendChild(r);
  });
}

$("q").oninput=render; $("town").onchange=render; $("when").onchange=render;
$("online").onchange=render; $("freeonly").onchange=render;
$("reset").onclick=()=>{$("q").value="";$("town").value="";$("when").value="";
  $("online").checked=false; $("freeonly").checked=false;
  active.clear();[...$("cats").children].forEach(c=>c.classList.remove("on"));render();};
render();

// Share a single event. Uses the native share sheet on phones; falls back to
// copying the link on desktop. e.stopPropagation so it never triggers the row.
$("list").addEventListener("click", async ev => {
  const b = ev.target.closest(".sharebtn");
  if(!b) return;
  ev.preventDefault(); ev.stopPropagation();
  // Prefer the clean short link (whatsonnice.com/jasmine); fall back to ?e=<fp>.
  const se = FP_MAP.get(b.dataset.fp);
  const url = se && se.slug ? (LINKBASE + se.slug)
                            : (SITE + "?e=" + encodeURIComponent(b.dataset.fp));
  const title = b.dataset.title || "Event in Nice";
  if(navigator.share){
    try { await navigator.share({title:"What's on in Nice", text:title, url}); } catch(_){}
  } else if(navigator.clipboard){
    try { await navigator.clipboard.writeText(url);
      b.setAttribute("data-copied","1"); setTimeout(()=>b.removeAttribute("data-copied"),1500);
    } catch(_){}
  }
});

// ---- Add to calendar: build an .ics on the fly and hand it to the OS. ----
// Opening a .ics on iOS/Android drops straight into Apple/Google Calendar; on
// desktop it downloads. Times are floating (local-as-shown) — no timezone
// juggling, which is right for a listings site.
const p2 = n => String(n).padStart(2,"0");
const icsEsc = s => String(s||"").replace(/\\/g,"\\\\").replace(/[;,]/g,"\\$&").replace(/\n/g,"\\n");
const dOnly = d => d.replace(/-/g,"");
function icsFor(e){
  const stamp = new Date().toISOString().replace(/[-:]/g,"").replace(/\.\d+/,"");
  let dtstart, dtend;
  if(isMultiDay(e)){                                   // exhibition etc: all-day range
    dtstart = "DTSTART;VALUE=DATE:"+dOnly(e.start);
    dtend   = "DTEND;VALUE=DATE:"+dOnly(addDays(e.end,1));   // DTEND is exclusive
  } else if(e.time){                                   // timed: default 2h long
    const s = new Date(e.start+"T"+e.time+":00");
    const t = new Date(s.getTime()+2*3600*1000);
    const f = x => `${x.getFullYear()}${p2(x.getMonth()+1)}${p2(x.getDate())}T${p2(x.getHours())}${p2(x.getMinutes())}00`;
    dtstart = "DTSTART:"+f(s); dtend = "DTEND:"+f(t);
  } else {                                             // single day, no time: all-day
    dtstart = "DTSTART;VALUE=DATE:"+dOnly(e.start);
    dtend   = "DTEND;VALUE=DATE:"+dOnly(addDays(e.start,1));
  }
  const loc  = icsEsc([e.venue, e.town].filter(Boolean).join(", "));
  const desc = icsEsc([e.note, e.url].filter(Boolean).join("\n"));
  return ["BEGIN:VCALENDAR","VERSION:2.0","PRODID:-//whatsonnice//EN","CALSCALE:GREGORIAN",
    "BEGIN:VEVENT","UID:"+e.fingerprint+"@whatsonnice.com","DTSTAMP:"+stamp,
    dtstart, dtend, "SUMMARY:"+icsEsc(e.title),
    loc?"LOCATION:"+loc:"", desc?"DESCRIPTION:"+desc:"", e.url?"URL:"+e.url:"",
    "END:VEVENT","END:VCALENDAR"].filter(Boolean).join("\r\n");
}
$("list").addEventListener("click", ev => {
  const b = ev.target.closest(".calbtn");
  if(!b) return;
  ev.preventDefault(); ev.stopPropagation();
  const e = FP_MAP.get(b.dataset.fp);
  if(!e) return;
  const blob = new Blob([icsFor(e)], {type:"text/calendar;charset=utf-8"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = (e.title||"event").replace(/[^\w-]+/g,"_").slice(0,40)+".ics";
  document.body.appendChild(a); a.click();
  setTimeout(()=>{ URL.revokeObjectURL(url); a.remove(); }, 1500);
});

// ---- Shareable event card: a blue, rounded PNG people can post ----
// Drawn entirely in-browser on a <canvas> — no server, no upload. On phones it
// opens the native share sheet with the image attached (Instagram, WhatsApp,
// Messages…); on desktop it downloads a PNG. Portrait 1080×1350 = story/feed safe.
function roundRectPath(x,cx,cy,w,h,r){
  if(x.roundRect){ x.beginPath(); x.roundRect(cx,cy,w,h,r); return; }
  x.beginPath(); x.moveTo(cx+r,cy);
  x.arcTo(cx+w,cy,cx+w,cy+h,r); x.arcTo(cx+w,cy+h,cx,cy+h,r);
  x.arcTo(cx,cy+h,cx,cy,r); x.arcTo(cx,cy,cx+w,cy,r); x.closePath();
}
function wrapLines(x,text,maxW){
  const words=String(text||"").split(/\s+/), lines=[]; let line="";
  for(const w of words){
    const t=line?line+" "+w:w;
    if(x.measureText(t).width>maxW && line){ lines.push(line); line=w; } else line=t;
  }
  if(line) lines.push(line);
  return lines;
}
function cardDateText(e){
  const d=new Date(e.start+"T12:00:00");
  const dm=d.toLocaleDateString("en-GB",{day:"numeric",month:"long"});
  const wd=d.toLocaleDateString("en-GB",{weekday:"long"});
  if(isMultiDay(e)){
    const end=new Date(e.end+"T12:00:00").toLocaleDateString("en-GB",{day:"numeric",month:"long"});
    return { big: dm, small: "UNTIL "+end.toUpperCase() };
  }
  return { big: dm, small: (wd+(e.time?(" · "+e.time):"")).toUpperCase() };
}
// QR encoder, lazy-loaded only when a card is first made (like the OCR reader).
// If it fails to load (offline), the card still renders with the text link — the
// QR is a bonus, never a dependency.
let _qrLoading=null;
function loadQR(){
  if(window.qrcode) return Promise.resolve(true);
  if(_qrLoading) return _qrLoading;
  _qrLoading=new Promise(res=>{
    const s=document.createElement("script");
    s.src="https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.js";
    s.onload=()=>res(true); s.onerror=()=>res(false);
    document.head.appendChild(s);
  });
  return _qrLoading;
}
// Draw a QR straight onto the blue card: white modules, no tile, a 4-cell quiet
// zone of blue around it. Cleaner than a boxed code. (White-on-blue is inverted
// from the usual dark-on-light; modern phone cameras read it fine thanks to the
// strong contrast, but it's the one thing worth a real-world scan-test.)
function drawQR(x,url,px,py,size){
  if(!window.qrcode) return false;
  try{
    const qr=window.qrcode(0,"M"); qr.addData(url); qr.make();
    const n=qr.getModuleCount(), quiet=4, total=n+quiet*2, cell=size/total;
    x.fillStyle="#fff";
    for(let r=0;r<n;r++) for(let c=0;c<n;c++) if(qr.isDark(r,c))
      x.fillRect(px+(c+quiet)*cell, py+(r+quiet)*cell, Math.ceil(cell), Math.ceil(cell));
    return true;
  }catch(_){ return false; }
}
// A short, friendly tag from the title: drop event-type filler and articles,
// keep the first couple of distinctive words. "Exposition Jasmine" -> "jasmine",
// "Vernissage de l'artiste Jasmine" -> "jasmine".
const CARD_STOP = new Set(("vernissage exposition expo concert soiree spectacle atelier festival "
  + "brocante marche visite balade projection l la le les de des du au aux un une et "
  + "the a of at in on and with avec artiste artist en fete").split(" "));
function cardSlug(title){
  const words = (title||"").normalize("NFD").replace(/[̀-ͯ]/g,"")
    .toLowerCase().replace(/[^a-z0-9\s]/g," ").split(/\s+/).filter(Boolean);
  const keep = words.filter(w=>!CARD_STOP.has(w) && w.length>1);
  return (keep.length?keep:words).slice(0,2).join("-");
}
// No em/en dashes on cards, in any title — collapse them to a plain hyphen.
const cardTitle = t => (t||"").replace(/\s*[—–]\s*/g, " - ");

async function buildEventCard(e){
  await loadQR();                       // best-effort; card renders either way
  const W=1080,H=1350, F="'Helvetica Neue',Arial,sans-serif";
  const c=document.createElement("canvas"); c.width=W; c.height=H;
  const x=c.getContext("2d");
  x.fillStyle="#f4f2ed"; x.fillRect(0,0,W,H);                 // paper background
  const m=60, r=64;                                          // card margin + radius
  roundRectPath(x,m,m,W-2*m,H-2*m,r); x.fillStyle="#1f3bff"; x.fill();
  const L=m+72, R=W-m-72, iw=R-L; let y=m+150;
  const dt=cardDateText(e);
  x.textBaseline="alphabetic"; x.textAlign="left";
  x.fillStyle="rgba(255,255,255,.72)"; x.font="600 30px "+F;
  x.fillText("WHAT’S ON IN NICE", L, y); y+=76;
  x.fillStyle="#fff"; x.font="800 86px "+F;
  x.fillText(dt.big, L, y); y+=52;
  x.fillStyle="rgba(255,255,255,.85)"; x.font="500 34px "+F;
  x.fillText(dt.small, L, y); y+=94;
  // Title: shrink from 76px until it fits in 4 lines, then clamp. No em dashes.
  const title=cardTitle(e.title);
  let fs=76; x.fillStyle="#fff"; x.font="800 "+fs+"px "+F;
  let lines=wrapLines(x,title,iw);
  while(lines.length>4 && fs>46){ fs-=6; x.font="800 "+fs+"px "+F; lines=wrapLines(x,title,iw); }
  const lh=fs*1.12;
  lines.slice(0,4).forEach(l=>{ y+=lh; x.fillText(l,L,y); });
  y+=54;
  x.strokeStyle="rgba(255,255,255,.35)"; x.lineWidth=2;
  x.beginPath(); x.moveTo(L,y); x.lineTo(R,y); x.stroke(); y+=64;
  x.fillStyle="#fff"; x.font="700 42px "+F;
  wrapLines(x,(e.venue||e.town),iw).slice(0,2).forEach(l=>{ x.fillText(l,L,y); y+=50; });
  if(e.venue){ x.fillStyle="rgba(255,255,255,.8)"; x.font="500 34px "+F; x.fillText(e.town,L,y); }
  // Footer: a small wordmark + short link on the left, a compact QR on the right,
  // all sitting on the same bottom line.
  // Real short link: whatsonnice.com/<slug>. The QR carries the full URL; the
  // printed text shows host + /slug in two tones. e.slug is assigned at build and
  // is unique + resolvable; cardSlug(title) is only the fallback for a just-
  // submitted event that isn't in the data yet (its link points at the site root).
  const slug = e.slug || cardSlug(e.title);
  const link = e.slug ? (LINKBASE + e.slug)
             : (e.fingerprint ? (LINKBASE + "?e=" + e.fingerprint) : LINKBASE);
  const qs=146, base=H-m-46;
  drawQR(x, link, R-qs, base-qs, qs);
  x.textAlign="left";
  x.fillStyle="rgba(255,255,255,.7)"; x.font="600 25px "+F;
  x.fillText((CATNAME[e.category]||e.category).toUpperCase(), L, base-76);
  x.fillStyle="#fff"; x.font="700 32px "+F;
  x.fillText(HOSTDISP, L, base-30);
  if(slug){
    const w=x.measureText(HOSTDISP).width;
    x.fillStyle="rgba(255,255,255,.72)"; x.font="500 32px "+F;
    x.fillText("/"+slug, L+w, base-30);
  }
  return await new Promise(res=>c.toBlob(res,"image/png"));
}
async function shareEventCard(e, btn){
  if(btn) btn.setAttribute("data-busy","1");
  try{
    const blob=await buildEventCard(e);
    const fname=(e.title||"event").replace(/[^\w-]+/g,"_").slice(0,40)+".png";
    const file=new File([blob],fname,{type:"image/png"});
    if(navigator.canShare && navigator.canShare({files:[file]})){
      try{ await navigator.share({files:[file], title:e.title, text:"What’s on in Nice"}); return; }
      catch(_){ /* user cancelled the sheet → fall through to a download */ }
    }
    const url=URL.createObjectURL(blob);
    const a=document.createElement("a"); a.href=url; a.download=fname;
    document.body.appendChild(a); a.click();
    setTimeout(()=>{ URL.revokeObjectURL(url); a.remove(); },1500);
  }catch(_){ /* toBlob unsupported: nothing we can do, stay silent */ }
  finally{ if(btn) btn.removeAttribute("data-busy"); }
}
