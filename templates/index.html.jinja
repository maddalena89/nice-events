// No backend: hand off to a prefilled GitHub issue. Free, auditable, no server.
$("sform").addEventListener("submit", ev => {
  ev.preventDefault();
  const g = id => $(id).value.trim();
  const townCanon = TOWN_CANON.get(g("s-town").toLowerCase());
  if (!townCanon) { $("smsg").innerHTML = '<span class="err">Pick a town from the list as you type.</span>'; return; }
  if (!g("s-url")) { $("smsg").innerHTML = '<span class="err">A link is required as proof.</span>'; return; }
  try { new URL(g("s-url")); }
  catch { $("smsg").innerHTML = '<span class="err">That link isn\'t a valid URL.</span>'; return; }
  const body = [
    `**Event:** ${g("s-title")}`, `**Date:** ${g("s-date")}${g("s-end") ? " → " + g("s-end") : ""}`,
    `**Town:** ${townCanon}`, `**Venue:** ${g("s-venue") || "—"}`,
    `**Category:** ${$("s-cat").value}`, `**Link:** ${g("s-url")}`,
    `**Note:** ${g("s-note") || "—"}`, `**From:** ${g("s-email") || "anonymous"}`,
  ].join("\n");
  window.open("https://github.com/{{ github_repo }}/issues/new?labels=submission&title=" +
    encodeURIComponent("Event: " + g("s-title")) + "&body=" + encodeURIComponent(body), "_blank");
  $("smsg").innerHTML = '<span class="ok">Opening a submission for review…</span>';
});
{% endif %}

// ---- PWA: register the service worker, and AUTO-UPDATE ----
// The hard-won lesson: an installed app happily serves a months-old cached copy
// and nobody knows to clear it. So we actively pull updates. On every load we
// ask the browser to re-check sw.js; when a new worker takes control we reload
// once (guarded against loops). The worker itself calls skipWaiting, so a new
// version activates immediately instead of waiting for every tab to close.
if ("serviceWorker" in navigator) {
  let reloading = false;
  navigator.serviceWorker.addEventListener("controllerchange", () => {
    if (reloading) return;
    reloading = true;
    location.reload();
  });
  window.addEventListener("load", () => {
    navigator.serviceWorker.register("sw.js").then(reg => {
      reg.update();                                  // check for a newer worker now
      setInterval(() => reg.update(), 60 * 60 * 1000);  // and hourly while open
    }).catch(() => {});
  });
}
</script>
</body>
</html>
